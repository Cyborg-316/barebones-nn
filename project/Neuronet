import math
import random

inputCache = []
outputCache = []

lr = 0.05
weights = []
biases = []

numInputs = 1
numNeurons = 15
numHiddenLayers = 1
numOutputs = 1

def setCaches(size):
    for i in range(size + 1):
        val = [i]
        val2 = [(val[0] ** 2)]
        inputCache.append(val)
        outputCache.append(val2)

def Cost(x, y):
    return (x - y) ** 2

def dCost(x,y):
    return 2 * (x - y)

def shuffleData(data, data2):
    newData = data
    newData2 = data2
    for epoch in range(1000):
        index = random.randint(0,len(newData)) - 1
        index2 = random.randint(0,len(newData)) - 1
        while index2 == index:
            index2 = random.randint(0,len(newData)) - 1
        temp = newData[index2]
        newData[index2] = newData[index]
        newData[index] = temp

        temp = newData2[index2]
        newData2[index2] = newData2[index]
        newData2[index] = temp
    return newData, newData2       

def relu(x):
    return max(0, x)

def d_relu(x):
    return 1 if 0 < x else 0

def sigmoid(x):
    return 1 / (1 + math.exp(-x))

def d_sigmoid(x):
    return sigmoid(x) * (1 - sigmoid(x))

def average(data):
    return sum(data) / len(data)

def maxData(data):
    temp = []
    for i in range(len(data)):
        temp.append(data[i][0])
    return max(temp)

def addListtoList(List, amt):
    temp = []
    for i in range(amt):
        temp.append(random.uniform(-0.05,0.05))
    if amt > 0:
        List.append(temp)
    else:
        List.append([0])

def addListtoListVal(List, amt, Value):
    temp = []
    for i in range(amt):
        temp.append(Value)
    if amt > 0:
        List.append(temp)
    else:
        List.append([Value])

def init_layers(hiddenLayers, n, inputs, outputs):
    connections = n * inputs + n * outputs + (n ** 2) * (numHiddenLayers - 1)
    biases.append(0)
    weights.append(0)
    weights.append([])
    if numHiddenLayers > 0:
        for i in range(hiddenLayers):
            addListtoListVal(biases, n, 0)
        addListtoListVal(biases, outputs, 0)
        
        for i in range(n):
            addListtoList(weights[1],inputs)
        for i in range(hiddenLayers - 1):
            weights.append([])
            for i in range(n):
                addListtoList(weights[-1],n)
        for i in range(outputs):
            weights.append([])
            addListtoList(weights[-1],n)
    else:
        addListtoListVal(biases, outputs, 0)
        for i in range(outputs):
            addListtoList(weights[1],inputs)
    
def normalize(data):
    maxVal = maxData(data)

    normalizedData = []
    for i in range(len(data)):
        addListtoList(normalizedData, 1)

    for i in range(len(data)):
        normalizedData[i][0] = data[i][0] / maxVal

    return normalizedData

def trainNetwork(iterations, learningRate):
    for epoch in range(iterations):
        global inputCache
        global outputCache

        weightGradients = []
        biasGradients = []
        weightGradients.append(0)
        biasGradients.append(0)
        weightGradients.append([])
        if numHiddenLayers > 0:
            for i in range(numHiddenLayers):
                addListtoListVal(biasGradients, numNeurons, 0)
            addListtoListVal(biasGradients, numOutputs, 0)

            for i in range(numNeurons):
                addListtoListVal(weightGradients[1], numInputs, 0)
            for i in range(numHiddenLayers - 1):
                weightGradients.append([])
                for i in range(numNeurons):
                    addListtoListVal(weightGradients[-1], numNeurons, 0)
            for i in range(numOutputs):
                weightGradients.append([])
                addListtoListVal(weightGradients[-1], numNeurons, 0)
        else:
            for i in range(numOutputs):
                addListtoListVal(weightGradients[1], numInputs, 1)
            addListtoListVal(biasGradients, numOutputs, 1)
        
        for subListIndex in range(len(inputCache)):
            #forward pass
            outputs = outputCache[subListIndex]
            inputs = inputCache[subListIndex]
            
            activations = []
            z = []
            activations.append(inputs)
            z.append(inputs)
            for i in range(numHiddenLayers):
                addListtoList(activations, numNeurons)
                addListtoList(z, numNeurons)
            addListtoListVal(activations, numOutputs, 0)
            addListtoListVal(z, numNeurons, 0)

            for indexValue, L in enumerate(activations):
                if indexValue > 0 and indexValue < len(activations) - 1:
                    for j in range(len(L)):
                        temp = 0
                        for i in range(len(activations[indexValue - 1])):
                            temp += weights[indexValue][j][i] * activations[indexValue - 1][i]
                        temp += biases[indexValue][j]
                        z[indexValue][j] = temp
                        activations[indexValue][j] = relu(temp)
                elif indexValue == len(activations) - 1:
                    for j in range(len(L)):
                        temp = 0
                        for i in range(len(activations[indexValue - 1])):
                            temp += weights[indexValue][j][i] * activations[indexValue - 1][i]
                        temp += biases[indexValue][j]
                        z[indexValue][j] = temp
                        activations[indexValue][j] = temp
            predicted = z[-1][0]
            
            #back prop
            deltas = []
            deltas.append(inputs)
            for i in range(numHiddenLayers):
                addListtoList(deltas, numNeurons)
            addListtoList(deltas, numOutputs)

            for j in range(len(deltas[-1])):
                deltas[-1][j] = dCost(predicted, outputs[0])
            for indexLayer in reversed(range(len(deltas) - 1)):
                if indexLayer > 0:
                    for i in range(len(deltas[indexLayer])):
                        summ = 0
                        for j in range(len(deltas[indexLayer + 1])):
                            summ += weights[indexLayer + 1][j][i] * deltas[indexLayer + 1][j]
                        deltas[indexLayer][i] = summ * d_relu(z[indexLayer][i])

            #updating gradients
            for indexLayer in range(len(weights)):
                if indexLayer > 0:
                    for j in range(len(weights[indexLayer])):
                        for i in range(len(weights[indexLayer][j])):
                            gradient = deltas[indexLayer][j] * activations[indexLayer - 1][i] + weightGradients[indexLayer][j][i]
                            weightGradients[indexLayer][j][i] = gradient
            
            for indexLayer, layer in enumerate(biases):
                if indexLayer > 0:
                    for j in range(len(layer)):
                        gradient = deltas[indexLayer][j] + biasGradients[indexLayer][j]
                        biasGradients[indexLayer][j] = gradient

        #updating weights and biases
        for indexLayer in range(len(weights)):
            if indexLayer > 0:
                for j in range(len(weights[indexLayer])):
                    for i in range(len(weights[indexLayer][j])):
                        temp = weights[indexLayer][j][i] - lr * weightGradients[indexLayer][j][i] / len(inputCache)
                        weights[indexLayer][j][i] = temp
        
        for indexLayer, layer in enumerate(biases):
            if indexLayer > 0:
                for j in range(len(layer)):
                    temp = biases[indexLayer][j] - lr * biasGradients[indexLayer][j] / len(inputCache)
                    biases[indexLayer][j] = temp

        #shuffling data
        inputCache, outputCache = shuffleData(inputCache, outputCache)
        

print("-------------------------RUNNING-------------------------")

setCaches(10)
inputCache, outputCache = shuffleData(inputCache, outputCache)
maxInput = maxData(inputCache)
maxOutput = maxData(outputCache)

inputCache = normalize(inputCache)
outputCache = normalize(outputCache)
init_layers(numHiddenLayers,numNeurons,numInputs,numOutputs)

iterations = 10000
trainNetwork(iterations, lr)
totalCost = []
for subListIndex in range(len(inputCache)):
    #forward pass
    outputs = outputCache[subListIndex]
    inputs = inputCache[subListIndex]
    inputt = inputs[0]
    output = outputs[0]

    activations = []
    z = []
    activations.append(inputs)
    z.append(inputs)
    for i in range(numHiddenLayers):
        addListtoList(activations, numNeurons)
        addListtoList(z, numNeurons)
    addListtoListVal(activations, numOutputs, 0)
    addListtoListVal(z, numNeurons, 0)

    for indexValue, L in enumerate(activations):
        if indexValue > 0 and indexValue < len(activations) - 1:
            for j in range(len(L)):
                temp = 0
                for i in range(len(activations[indexValue - 1])):
                    temp += weights[indexValue][j][i] * activations[indexValue - 1][i]
                temp += biases[indexValue][j]
                z[indexValue][j] = temp
                activations[indexValue][j] = relu(temp)
        elif indexValue == len(activations) - 1:
            for j in range(len(L)):
                temp = 0
                for i in range(len(activations[indexValue - 1])):
                    temp += weights[indexValue][j][i] * activations[indexValue - 1][i]
                temp += biases[indexValue][j]
                z[indexValue][j] = temp
                activations[indexValue][j] = temp
    predicted = z[-1][0]
    printedPredicted = predicted * maxOutput
    printedInput = inputt * maxInput
    printedOutput = output * maxOutput
    cost = Cost(printedPredicted, printedOutput)

    print(f"Input: {printedInput:.2f}          Predicted: {printedPredicted:.2f}      Actual: {printedOutput:.2f}      Cost: {cost:2f}")
    totalCost.append(cost)
print(f"Average Cost: {average(totalCost):2f}                 Iterations:", iterations)


