# practice neural network
# Assuming 1 output for now, will add more later
# Will be using backpropagation to train the network, 
# will be using mean squared error as the cost function, 
# and sigmoid as the activation function

import math

inputCache = [[0,0,0]]#,[100,50,0],[200,200,200],[950,376,215]]
outputCache = [[1]]#,[50],[200],[513.667]]

lr = 0.5
A = lambda x: 1 / (1 + math.exp(-1 * x))
dA = lambda x: A(x) * (1 - A(x))
C = lambda x, y: (x - y) ** 2
dC = lambda x, y: 2 * (x - y)
weights = []
biases = []

numInputs = 3
numNeurons = 2
numHiddenLayers = 3
numOutputs = 1

def addListtoList(List, amt):
    temp = []
    for i in range(amt):
        temp.append(1)
    List.append(temp)

def init_layers(hiddenLayers, n, inputs, outputs):
    connections = n * inputs + n * outputs + (n ** 2) * (numHiddenLayers - 1)
    biases.append("Layer0")
    weights.append("Layer0")
    weights.append([])
    if numHiddenLayers > 0:
        for i in range(hiddenLayers):
            addListtoList(biases, n)
        addListtoList(biases, outputs)
        
        for i in range(n):
            addListtoList(weights[1],inputs)
        for i in range(hiddenLayers - 1):
            weights.append([])
            for i in range(n):
                addListtoList(weights[-1],n)
        for i in range(outputs):
            weights.append([])
            addListtoList(weights[-1],n)
    else:
        addListtoList(biases, outputs)
        weights.append.append([])
        for i in range(outputs):
            addListtoList(weights[1],inputs)

def trainNetwork(iterations, learningRate):
        for epoch in range(iterations):
            for subListIndex in range(len(inputCache)):
                #initializing the lists for the forward pass
                outputs = outputCache[subListIndex]
                output = outputs[0]
                weightedSums = []
                weightedSums.append(inputCache[subListIndex])
                for i in range(numHiddenLayers):
                    addListtoList(weightedSums, numNeurons)
                addListtoList(weightedSums, numOutputs)
                z = weightedSums
                
                #calculating weighted sums (maps input(s) to output(s))
                for indexValue, L in enumerate(weightedSums):
                    if indexValue > 0:
                        for j in range(len(L)):
                            temp = 0
                            for i in range(len(weightedSums[indexValue - 1])):
                                temp += weights[indexValue][j][i] * weightedSums[indexValue - 1][i]
                            temp += biases[indexValue][j]
                            z[indexValue][j] = temp
                            weightedSums[indexValue][j] = A(temp)
                
                #finding delta for gradients
                deltas = ['layer0']
                for i in range(numHiddenLayers):
                    addListtoList(deltas, numNeurons)
                addListtoList(deltas, numOutputs)

                for j in range(len(deltas[-1])):
                    deltas[-1][j] = dC(weightedSums[-1][j], output)  * dA(z[-1][j])
                for temp in range(numHiddenLayers):
                    indexLayer = numHiddenLayers - temp
                    for j in range(len(deltas[indexLayer])):
                        summ = 0
                        for k in range(len(deltas[indexLayer + 1])):
                            summ += weights[indexLayer][k][j] * deltas[indexLayer + 1][k]
                        deltas[indexLayer][j] = summ * dA(z[indexLayer][j])
                    
                #updating weights and biases    
                for indexLayer, layer in enumerate(weights):
                    if indexLayer > 0:
                        for j, temp in enumerate(layer):
                            for i in range(len(temp)):
                                weights[indexLayer][j][i] -= lr * deltas[indexLayer][j] * weightedSums[indexLayer - 1][i]
                
                for indexLayer, layer in enumerate(biases):
                    if indexLayer > 0:
                        for j, bias in enumerate(layer):
                            biases[indexLayer][j] -= lr * deltas[indexLayer][j]
                            
                print(weightedSums[-1][0])
    
    
    
init_layers(numHiddenLayers,numNeurons,numInputs,numOutputs)  
trainNetwork(1000, lr)
